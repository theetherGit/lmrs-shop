{
    "name": "lmrs-shop",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "gen": "wrangler types",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@better-auth/cli": "latest",
        "@eslint/compat": "^2.0.2",
        "@eslint/js": "^9.39.2",
        "@fontsource-variable/geist": "^5.2.8",
        "@fontsource-variable/nunito-sans": "^5.2.7",
        "@internationalized/date": "^3.12.0",
        "@libsql/client": "^0.17.2",
        "@lucide/svelte": "^0.577.0",
        "@sveltejs/adapter-cloudflare": "latest",
        "@sveltejs/kit": "^2.55.0",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tabler/icons-svelte": "^3.40.0",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/table-core": "^8.21.3",
        "@types/node": "^22",
        "@vitejs/devtools": "^0.1.8",
        "better-auth": "~1.4.22",
        "bits-ui": "^2.16.3",
        "clsx": "^2.1.1",
        "dotenv": "^17.3.1",
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.1",
        "eslint": "^9.39.2",
        "eslint-plugin-svelte": "^3.14.0",
        "formsnap": "^2.0.1",
        "globals": "^17.3.0",
        "jsrepo": "^3.7.0",
        "layerchart": "2.0.0-next.43",
        "mode-watcher": "^1.1.0",
        "runed": "^0.37.1",
        "svelte": "^5.53.10",
        "svelte-check": "^4.4.5",
        "svelte-sonner": "^1.1.0",
        "svelte-toolbelt": "^0.10.6",
        "sveltekit-superforms": "^2.30.0",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.54.0",
        "vaul-svelte": "1.0.0-next.7",
        "vite": "8.0.2",
        "vite-plugin-devtools-json": "^1.0.0",
        "wrangler": "^4.73.0"
    },
    "packageManager": "pnpm@10.32.1"
}
